{
    "name": "charlson_comorbidity_index_calculation_workflow",
    "description": "Calculate the Charlson Comorbidity Index (CCI) score by summing the weights of present comorbid conditions and adding an age adjustment score.",
    "inputs": [
        {
            "input_name": "age",
            "input_desc": "Patient's age in years",
            "input_type": "int"
        },
        {
            "input_name": "mi",
            "input_desc": "Myocardial infarction present (true/false)",
            "input_type": "bool"
        },
